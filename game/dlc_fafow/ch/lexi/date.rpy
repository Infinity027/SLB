    show lexi a lollipop
    mike.say "Urgh..."
    mike.say "Geez, Lexi..."
    mike.say "It's literally hours until the park closes."
    mike.say "We've got all the time in the world before then."
    show lexi a annoyed
    "Lexi shakes her head at this."
    show lexi a bored
    lexi.say "Uh-uh..."
    show lexi a normal
    lexi.say "We need to factor in queuing times."
    lexi.say "Then there's toilet breaks."
    lexi.say "And stopping for regular snacks - I need to keep my energy levels up!"
    show lexi a blank
    mike.say "I'm sure we'll be fine, Lexi..."
    mike.say "Now can we actually get in there?"
    show lexi b smile nophone
    "Lexi nods and grabs hold of my hand."
    "Then I find myself being dragged through the gate and into the crowds beyond."
    return

label lexi_date_ferris_wheel_male:
