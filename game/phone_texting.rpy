define nvl_mode = "phone"

init -1 python:
    phone_show_hero = True  
    def Phone_ReceiveSound(event, interact=True, **kwargs):
        if event == "show_done":
            renpy.sound.play("sd/msg_send.ogg", channel="sound")
    def Phone_SendSound(event, interact=True, **kwargs):
        if event == "show_done":
            renpy.sound.play("sd/cell_vibrate.ogg", channel="sound")

transform message_appear(pDirection):
    alpha 0.0
    xoffset 25 * pDirection
    parallel:
        ease 0.5 alpha 1.0
    parallel:
        easein_back 0.5 xoffset 0

transform message_appear_icon():
    zoom 0.0
    easein_back 0.5 zoom 1.0

transform message_narrator:
    alpha 0.0
    yoffset -25

    parallel:
        ease 0.5 alpha 1.0
    parallel:
        easein_back 0.5 yoffset 0

screen PhoneDialogue(dialogue, items=None):
    predict False
    if phone_show_hero:
        if hero.is_male:
            add hero.layered_image() + " p down" xalign 0.3 yalign 1.0
        else:
            add hero.layered_image() xalign 0.3 yalign 1.0
    style_prefix "phoneFrame"
    frame:
        xalign 0.75
        yalign 0.7
        has viewport
        draggable True
        mousewheel True
        yinitial 1.0
        vbox:
            null height 10
            use nvl_phonetext(dialogue)
            null height 50

screen nvl_phonetext(dialogue):
    style_prefix None

    $ previous_d_who = None
    for id_d, d in enumerate(dialogue):
        if d.who == None:
            text d.what:
                xpos -167
                ypos 0.0
                xsize 175
                text_align 0.5
                italic True
                size 14
                slow_cps False
                id d.what_id
                if d.current:
                    at message_narrator
        else:
            if d.who == "mc":
                $ message_frame = "gui/phone/message/phone_send_frame.png"
            else:
                $ message_frame = "gui/phone/message/phone_received_frame.png"

            hbox:
                spacing 10
                if d.who == "mc":
                    box_reverse True
                    xalign 1.0


                if previous_d_who != d.who:
                    $ message_is_send = False
                    if d.who == "mc":
                        $ message_is_send = True
                        if hero.is_female:
                            $ message_icon = "sayicon bree"
                        else:
                            $ message_icon = "sayicon mike"
                    elif d.who == bree.name:
                        $ message_icon = "sayicon bree"
                    elif d.who == mike.name:
                        $ message_icon = "sayicon mike"
                    elif renpy.has_image(f"sayicon {d.who.lower()}"):
                        $ message_icon = f"sayicon {d.who.lower()}"
                    else:
                        $ message_icon = "gui/phone/message/phone_received_icon.png"
                    frame xsize 50 ysize 50 style "empty":
                        if message_is_send:
                            add "gui/phone/message/phone_send_icon.png" xsize 50 ysize 50
                        else:
                            add "gui/phone/message/phone_received_icon.png" xsize 50 ysize 50
                        add message_icon xsize 50 ysize 50
                        if d.current:
                            at message_appear_icon()

                else:
                    null width 50

                vbox:
                    yalign 1.0
                    if d.who != "mc" and previous_d_who != d.who:
                        text d.who
                    elif d.who == "mc" and previous_d_who != d.who:
                        text "Me"

                    frame:
                        padding (10, 10)

                        background Frame(message_frame, 16,16,16,16)
                        xsize 195

                        if d.current:
                            if d.who == "mc":
                                at message_appear(1)
                            else:
                                at message_appear(-1)

                        text d.what:
                            pos (0, 0)
                            xsize 185
                            slow_cps False
                            size 18
                            color "#fff"
                            outlines [( 0, "#00000000", 0, 0)]
                            id d.what_id
        $ previous_d_who = d.who

